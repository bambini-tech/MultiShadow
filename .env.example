# ---------------------------------------------------------------------------
# MultiShadow environment configuration
# Copy to .env (never commit .env). The Houdini API key is SERVER-SIDE ONLY —
# it must never appear in a variable that the frontend bundle can read.
# ---------------------------------------------------------------------------

# ==== Server-side only (apps/api) ==========================================
# Houdini partner API key. NEVER expose to the browser.
HOUDINI_API_KEY=your_houdini_partner_api_key

# Houdini partner API v2 base URL. The docs use a /v2 base and authenticate as
# `Authorization: <api-key>` (raw key, NO "Bearer " prefix).
# https://docs.houdiniswap.com/api-reference
HOUDINI_BASE_URL=https://api-partner.houdiniswap.com/v2

# Auth scheme — override only if the docs change. Defaults match v2 above.
HOUDINI_API_KEY_HEADER=Authorization
# "true" sends "Bearer <key>"; default (unset/false) sends the raw key.
HOUDINI_BEARER=false

# Solana RPC endpoint used for building/simulating/sending transactions.
# A private/paid RPC is strongly recommended for reliability.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: comma-separated origins allowed to call the proxy (CORS).
# Leave empty to allow same-origin only.
ALLOWED_ORIGINS=http://localhost:5173

# ==== Client-side (apps/web) — safe to expose ==============================
# Reown (WalletConnect successor) AppKit project id. This is a public value.
VITE_REOWN_PROJECT_ID=your_reown_project_id

# Base URL of the deployed proxy. In local dev the Vite proxy handles /api.
VITE_API_BASE_URL=/api

# Public Solana RPC for the frontend (read-only usage; can differ from server).
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
